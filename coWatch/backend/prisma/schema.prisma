generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Existing models (kept for future use) ────────────────────────────────────

model Room {
  id        String       @id @default(cuid())
  roomCode  String       @unique
  name      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  sessions  Session[]
  members   RoomMember[]
  messages  Message[]
}

model Session {
  id          String      @id @default(cuid())
  tokenHash   String      @unique
  displayName String
  roomId      String
  room        Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  isAdmin     Boolean     @default(false)
  createdAt   DateTime    @default(now())
  expiresAt   DateTime
  revokedAt   DateTime?
  lastSeenAt  DateTime    @default(now())

  member      RoomMember?
  messages    Message[]

  @@index([roomId])
  @@index([expiresAt])
}

model RoomMember {
  id          String     @id @default(cuid())
  roomId      String
  room        Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sessionId   String     @unique
  session     Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  displayName String
  isAdmin     Boolean    @default(false)
  joinedAt    DateTime   @default(now())
  leftAt      DateTime?
  isActive    Boolean    @default(true)
  socketId    String?

  @@index([roomId, isActive])
  @@index([roomId, joinedAt])
}

model Message {
  id          String    @id @default(cuid())
  roomId      String
  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sessionId   String
  session     Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  displayName String
  text        String    @db.Text
  createdAt   DateTime  @default(now())

  @@index([roomId, createdAt])
}

// ─── ChatMessage: standalone model used by the socket chat feature ─────────────
// Uses roomCode (plain string, not a FK) so it works independently of the
// Room/Session models above. No need to create Room/Session rows first.

model ChatMessage {
  id        String   @id @default(cuid())
  roomCode  String   // matches the roomId string used in socket events
  userName  String
  text      String   @db.Text
  createdAt DateTime @default(now())

  @@index([roomCode, createdAt])
}